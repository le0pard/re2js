{
  "name": "re2js",
  "version": "2.5.0",
  "description": "RE2JS is the JavaScript port of RE2, a regular expression engine that provides linear time matching",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "re2js",
    "re2",
    "regex engine",
    "redos",
    "regex"
  ],
  "author": "Oleksii Vasyliev",
  "license": "MIT",
  "repository": "github:le0pard/re2js",
  "bugs": {
    "url": "https://github.com/le0pard/re2js/issues"
  },
  "homepage": "https://github.com/le0pard/re2js#readme",
  "files": [
    "build/",
    "README.md",
    "LICENSE"
  ],
  "main": "build/index.cjs.cjs",
  "module": "build/index.esm.js",
  "unpkg": "build/index.umd.js",
  "exports": {
    ".": {
      "types": "./build/index.esm.d.ts",
      "import": "./build/index.esm.js",
      "require": "./build/index.cjs.cjs"
    }
  },
  "types": "build/index.esm.d.ts",
  "scripts": {
    "build": "rollup -c && tsc",
    "dev": "rollup -c -w",
    "lint": "pnpify run prettier --check src tools *.config.js && eslint src/**/*.js tools/**/*.js babel.config.js vitest.config.js",
    "format": "pnpify run prettier --write src tools *.config.js",
    "test": "vitest run --project=node",
    "test:watch": "vitest --project=node",
    "test:browser": "vitest run --browser.enabled --project=browser",
    "coverage": "vitest run --project=node --coverage",
    "bench": "vitest bench --run --project=node"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/preset-env": "^7.29.5",
    "@eslint/js": "^9.39.4",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@unicode/unicode-17.0.0": "^1.6.16",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@yarnpkg/pnpify": "^4.1.6",
    "eslint": "9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.3.10",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.6.0",
    "lodash": "^4.18.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "rollup": "^4.60.3",
    "typescript": "^6.0.3",
    "unicode-property-value-aliases": "^3.9.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "yarn@4.14.1"
}
